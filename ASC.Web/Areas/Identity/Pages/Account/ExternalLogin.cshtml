@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Đăng nhập bằng Google";
}

<div class="container">
    <div class="row">
        <div class="col s12 m6 offset-m3">

            @* Trường hợp lỗi: email đã thuộc tài khoản Admin hoặc Engineer *@
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="card red lighten-4">
                    <div class="card-content red-text text-darken-4">
                        <span class="card-title">
                            <i class="material-icons left">error</i>
                            Đăng nhập thất bại
                        </span>
                        <p>@Model.ErrorMessage</p>
                    </div>
                    <div class="card-action">
                        <a href="/Identity/Account/Login" class="red-text text-darken-4">
                            ← Quay lại trang đăng nhập
                        </a>
                    </div>
                </div>
            }
            else
            {
                @* Trường hợp thành công: đang xử lý tự động *@
                <div class="card green lighten-4">
                    <div class="card-content green-text text-darken-4">
                        <span class="card-title">
                            <i class="material-icons left">check_circle</i>
                            Xác thực thành công
                        </span>
                        <p>
                            Bạn đã xác thực thành công với
                            <strong>@Model.ProviderDisplayName</strong>.
                        </p>
                        <p>Hệ thống đang tự động tạo tài khoản và chuyển hướng...</p>
                    </div>
                </div>

                @* Form ẩn — tự động submit để hoàn tất đăng ký *@
                <form id="auto-submit-form"
                      asp-page-handler="Confirmation"
                      asp-route-returnUrl="@Model.ReturnUrl"
                      method="post">
                    <input asp-for="Input.Email" type="hidden" />
                    @Html.AntiForgeryToken()
                </form>

                @section Scripts {
                    <script>
                        // Tự động submit form sau khi Google callback thành công
                        document.addEventListener("DOMContentLoaded", function () {
                            document.getElementById("auto-submit-form").submit();
                        });
                    </script>
                }
            }

        </div>
    </div>
</div>