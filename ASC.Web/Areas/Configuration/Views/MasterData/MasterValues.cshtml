@model ASC.Web.Areas.Configuration.Models.MasterValuesViewModel
@using ASC.Model.Models

@{
    Layout = "_SecureLayout";

    var masterKeys = ViewBag.MasterKeys as IEnumerable<MasterDataKey>
                     ?? new List<MasterDataKey>();
}

<div>
    <div class="row"></div>

    <div class="row padding-top-20px padding-left-20px padding-right-20px">
        <div class="row z-depth-3">
            <div class="section white-text padding-left-10px blue-grey lighten-1">
                <h5>Master Values</h5>
            </div>
        </div>

        <div class="divider"></div>

        <div class="col s4 padding-bottom-15px">
            <select id="ddlMasterKeys" name="ddlMasterKeys">
                <option value="">--Select--</option>

                @foreach (var item in masterKeys)
                {
                    <option value="@item.PartitionKey">@item.PartitionKey</option>
                }
            </select>
            <label>Partition Key</label>
        </div>

        <div class="col s4 offset-s4 padding-bottom-15px right-align">
            <a class="modal-trigger waves-effect waves-light" href="#modal1">
                <img src="~/images/excel.png" width="30" height="30" />
            </a>
        </div>

        <div class="col s12 padding-bottom-15px">
            <table class="highlight centered" id="tblMasterValues">
                <thead>
                    <tr>
                        <th data-field="RowKey">Row Key</th>
                        <th data-field="PartitionKey">Partition Key</th>
                        <th data-field="Name">Name</th>
                        <th data-field="IsActive">Is Active</th>
                        <th data-field="Actions">Edit</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>

    <div class="row"></div>

    <div class="row z-depth-3">
        <div class="col s12 padding-0px">
            <div class="section white-text padding-left-10px blue-grey lighten-1">
                <h5>Master Value Details</h5>
            </div>

            <div class="divider"></div>

            <form asp-controller="MasterData"
                  asp-action="MasterValues"
                  method="post"
                  class="col s12"
                  id="formMasterValue">

                @Html.AntiForgeryToken()

                <div class="row">
                    <input type="hidden" asp-for="IsEdit" />
                    <input type="hidden" asp-for="MasterValueInContext.RowKey" />

                    <div class="input-field col s4">
                        <input asp-for="MasterValueInContext.RowKey"
                               id="Input_MasterKey_RowKey"
                               disabled="disabled" />
                        <label asp-for="MasterValueInContext.RowKey"></label>
                    </div>

                    <div class="input-field col s4">
                        <select id="Select_MasterValueInContext_PartitionKey"
                                asp-for="MasterValueInContext.PartitionKey">
                            <option value="">--Select--</option>

                            @foreach (var item in masterKeys)
                            {
                                <option value="@item.PartitionKey">@item.PartitionKey</option>
                            }
                        </select>
                        <label>Partition Key</label>
                    </div>

                    <div class="input-field col s4">
                        <input asp-for="MasterValueInContext.Name"
                               id="txtMasterValueName"
                               name="MasterValueInContext.Name"
                               class="validate" />
                        <label for="txtMasterValueName">Name</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s4">
                        <div class="switch">
                            <label>
                                Is Active
                                <input asp-for="MasterValueInContext.IsActive"
                                       id="chkMasterValueIsActive"
                                       name="MasterValueInContext.IsActive"
                                       type="checkbox"
                                       value="true" />
                                <span class="lever"></span>
                            </label>
                        </div>
                    </div>

                    <div class="input-field col s8 right-align">
                        <button class="btn waves-effect waves-light btnSubmit"
                                type="button"
                                name="action">
                            Create
                            <i class="material-icons right">send</i>
                        </button>

                        <button class="btn waves-effect waves-light reset red lighten-1"
                                type="button"
                                name="action">
                            Reset
                        </button>
                    </div>

                    <div class="row col s12 right-align" asp-validation-summary="All"></div>
                </div>
            </form>
        </div>

        <div class="row"></div>
    </div>
</div>

<div id="modal1" class="modal modal-fixed-footer">
    <div class="modal-content">
        <h4>Upload Excel</h4>
        <p>Upload the Excel file that contains all the master values.</p>

        <div class="row hide divErrors">
            <div class="col s12">
                <div class="card-panel red lighten-1">
                    <span class="white-text errors"></span>
                </div>
            </div>
        </div>

        <div class="progress hide">
            <div class="indeterminate"></div>
        </div>

        <form asp-controller="MasterData"
              asp-action="UploadExcel"
              asp-area="Configuration"
              method="post"
              enctype="multipart/form-data"
              id="formUploadExcel">

            @Html.AntiForgeryToken()

            <div class="file-field input-field">
                <div class="btn">
                    <span>File</span>
                    <input type="file" id="files" name="file" accept=".xlsx" />
                </div>

                <div class="file-path-wrapper">
                    <input class="file-path validate" type="text" />
                </div>

                <div class="input-field row right">
                    <button class="btn waves-effect waves-light btnUpload"
                            type="button"
                            name="action">
                        Upload
                        <i class="material-icons right">send</i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.modal').modal();
            $('select').formSelect();

            var token = $('input[name="__RequestVerificationToken"]').first().val();

            $.ajaxSetup({
                cache: false,
                headers: {
                    'RequestVerificationToken': token
                }
            });

            var table = $('#tblMasterValues').DataTable({
                ajax: {
                    url: '@Url.Action("MasterValuesByKey", "MasterData", new { area = "Configuration" })',
                    type: 'GET',
                    data: function (d) {
                        d.key = $('#ddlMasterKeys').val();
                    }
                },
                pageLength: 3,
                lengthMenu: [[3, 5, 10, -1], [3, 5, 10, 'All']],
                       columns: [
            {
                data: function (row) {
                    return row.RowKey || row.rowKey || '';
                }
            },
            {
                data: function (row) {
                    return row.PartitionKey || row.partitionKey || '';
                }
            },
            {
                data: function (row) {
                    return row.Name || row.name || '';
                }
            },
            {
                data: function (row) {
                    return row.IsActive ?? row.isActive ?? false;
                }
            },
            {
                data: null
            }
        ],
        columnDefs: [
            {
                targets: 3,
                render: function (data) {
                    if (data === true || data === 'true') {
                        return '<img src="/images/green_tick.png" width="30" height="30" />';
                    }

                    return '<img src="/images/red_cross.png" width="30" height="30" />';
                }
            },
            {
                targets: 4,
                orderable: false,
                render: function () {
                    return '<i class="small material-icons edit cursor-hand">mode_edit</i>';
                }
            }
        ]
            });

            $('#tblMasterValues').css('width', '100%');

            setTimeout(function () {
                $('select[name="tblMasterValues_length"]').formSelect();
            }, 300);

            $('#ddlMasterKeys').on('change', function () {
                table.ajax.reload();
            });

            $(document).on('click', '.edit', function () {
                var user = table.row($(this).parents('tr')).data();

                if (!user) {
                    return;
                }

                $('#IsEdit').val('True');

                       var rowKey = user.RowKey || user.rowKey || '';
        var partitionKey = user.PartitionKey || user.partitionKey || '';
        var name = user.Name || user.name || '';
        var isActive = user.IsActive ?? user.isActive ?? false;

        $('#MasterValueInContext_RowKey').val(rowKey);
        $('#Input_MasterKey_RowKey').val(rowKey);

        $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
        $('#Select_MasterValueInContext_PartitionKey').val(partitionKey);
        $('#Select_MasterValueInContext_PartitionKey').attr('disabled', 'disabled');
        $('#Select_MasterValueInContext_PartitionKey').formSelect();

        $('#txtMasterValueName').val(name);
        $('#txtMasterValueName').addClass('valid');

        $('#chkMasterValueIsActive').prop('checked', isActive === true || isActive === 'true');

                $('.btnSubmit').html('Save <i class="material-icons right">send</i>');

                $('.select-wrapper').removeClass('valid');

                M.updateTextFields();
            });

            $(document).on('click', '.reset', function (e) {
                e.preventDefault();

                $('#IsEdit').val('False');

                $('#MasterValueInContext_RowKey').val('');
                $('#Input_MasterKey_RowKey').val('');

                $('#txtMasterValueName').val('');
                $('#txtMasterValueName').removeClass('valid');

                $('#chkMasterValueIsActive').prop('checked', false);

                $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
                $('#Select_MasterValueInContext_PartitionKey').removeAttr('disabled');
                $('#Select_MasterValueInContext_PartitionKey').val('');
                $('#Select_MasterValueInContext_PartitionKey').formSelect();

                $('.btnSubmit').html('Create <i class="material-icons right">send</i>');

                $('.select-wrapper').removeClass('valid');

                M.updateTextFields();
            });

            $(document).on('click', '.btnSubmit', function (e) {
                e.preventDefault();

                console.log('CLICK CREATE');

                var selectedPartitionKey = $('#Select_MasterValueInContext_PartitionKey').val();
                var name = $('#txtMasterValueName').val();
                var isEditValue = $('#IsEdit').val();

                if (!selectedPartitionKey || selectedPartitionKey.trim() === '') {
                    alert('Vui lòng chọn Partition Key.');
                    return;
                }

                if (!name || name.trim() === '') {
                    alert('Vui lòng nhập Name.');
                    return;
                }

                var isEdit = false;

                if (isEditValue && isEditValue.toLowerCase() === 'true') {
                    isEdit = true;
                }

                        var masterData = {
            PartitionKey: selectedPartitionKey.trim(),
            Name: name.trim(),
            IsActive: $('#chkMasterValueIsActive').is(':checked')
        };

                if (isEdit) {
                    masterData.RowKey = $('#MasterValueInContext_RowKey').val();
                }

                console.log('DATA SEND:', masterData);

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("MasterValues", "MasterData", new { area = "Configuration" })',
                    data: {
                        masterValue: masterData,
                        isEdit: isEdit
                    },
                    success: function (data) {
                        console.log('CREATE SUCCESS:', data);

                        var key = selectedPartitionKey.trim();

                        $('#ddlMasterKeys').formSelect('destroy');
                        $('#ddlMasterKeys').val(key);
                        $('#ddlMasterKeys').formSelect();

                        table.ajax.reload();

                        $('.reset').click();

                        alert(isEdit ? 'Cập nhật Master Value thành công.' : 'Tạo Master Value thành công.');
                    },
                    error: function (xhr) {
                        console.log('CREATE ERROR:', xhr);

                        var message = 'Không tạo được Master Value.';

                        if (xhr.responseJSON) {
                            message = xhr.responseJSON.Text
                                || xhr.responseJSON.text
                                || xhr.responseJSON.Detail
                                || xhr.responseJSON.detail
                                || message;
                        }
                        else if (xhr.responseText) {
                            message = xhr.responseText;
                        }

                        alert(message);
                    }
                });
            });

            $(document).on('click', '.btnUpload', function (e) {
                e.preventDefault();

                var fileUpload = $('#files').get(0);
                var files = fileUpload.files;

                $('.divErrors').addClass('hide');
                $('.errors').html('');

                if (!files || files.length === 0) {
                    $('.divErrors').removeClass('hide');
                    $('.errors').html('Vui lòng chọn file Excel.');
                    return;
                }

                var data = new FormData();
                data.append('file', files[0]);

                $('.progress').removeClass('hide');

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("UploadExcel", "MasterData", new { area = "Configuration" })',
                    contentType: false,
                    processData: false,
                    data: data,
                    success: function (message) {
                        $('.progress').addClass('hide');

                        if (message.Success || message.success) {
                            window.location.reload();
                            return;
                        }

                        if (message.Error || message.error) {
                            $('.divErrors').removeClass('hide');

                            var msg = message.Text || message.text || 'Upload thất bại.';
                            var detail = message.Detail || message.detail;

                            if (detail) {
                                msg += '<br/><br/>Chi tiết: ' + detail;
                            }

                            $('.errors').html(msg);
                        }
                    },
                    error: function (xhr) {
                        $('.progress').addClass('hide');
                        $('.divErrors').removeClass('hide');

                        var msg = 'Upload thất bại.';

                        if (xhr.responseJSON) {
                            msg = xhr.responseJSON.Text
                                || xhr.responseJSON.text
                                || xhr.responseJSON.Detail
                                || xhr.responseJSON.detail
                                || msg;

                            var detail = xhr.responseJSON.Detail || xhr.responseJSON.detail;

                            if (detail && detail !== msg) {
                                msg += '<br/><br/>Chi tiết: ' + detail;
                            }
                        }
                        else if (xhr.responseText) {
                            msg = xhr.responseText;
                        }

                        $('.errors').html(msg);
                    }
                });
            });
        });
    </script>
}