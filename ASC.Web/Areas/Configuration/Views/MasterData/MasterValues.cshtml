@model ASC.Web.Areas.Configuration.Models.MasterValuesViewModel
@using ASC.Model.Models
@{
    Layout = "_SecureLayout";
}
<div>
<div class="row"></div>
<div class="row padding-top-20px padding-left-20px padding-right-20px">
    <div class="row z-depth-3">
        <div class="section white-text padding-left-10px blue-grey lighten-1">
            <h5>Master Values</h5>
        </div>
 </div>
        <div class="divider"></div>
        <div class="col s4 padding-bottom-15px">
            @* Dropdown trên cùng *@
            <select id="ddlMasterKeys">
                <option value="">--Select--</option>
                @if (ViewBag.MasterKeys != null)
                {
                    foreach (var key in (IEnumerable<ASC.Model.Models.MasterDataKey>)ViewBag.MasterKeys)
                    {
                        <option value="@key.PartitionKey">@key.Name</option>
                    }
                }
            </select>
            <label>Partition Key</label>
        </div>
        <div class="col s4 offset-s4 padding-bottom-15px right-align">
            <a class="modal-trigger waves-effect waves-light" href="#modal1">
                <img src="~/images/excel.png" width="30" height="30" />
            </a>
        </div>

        <div class="col s12 padding-bottom-15px">
            @* Display List of Master Values *@
            <table class="highlight centered" id="tblMasterValues">
                <thead>
                    <tr>
                        <th data-field="RowKey">Row Key</th>
                        <th data-field="PartitionKey">Partition Key</th>
                        <th data-field="Name">Name</th>
                        <th data-field="IsActive">Is Active</th>
                        <th data-field="Actions">Edit</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
    <div class="row"></div>

    @* Details Section *@
    <div class="row z-depth-3">
        <div class="col s12 padding-0px">
            <div class="section white-text padding-left-10px blue-grey lighten-1">
                <h5>Master Value Details</h5>
            </div>
            <div class="divider"></div>
            <form asp-controller="MasterData" asp-action="MasterValues" method="post" class="col s12" id="formMasterValue">
                <div class="row">
                    <input type="hidden" id="IsEdit" name="IsEdit" value="False" />
                    <input type="hidden" id="MasterValueInContext_RowKey" name="MasterValueInContext.RowKey" />
                    <input type="hidden" id="MasterValueInContext_PartitionKey" name="MasterValueInContext.PartitionKey" />

                    <!-- Row Key -->
                    <div class="input-field col s4">
                        <input type="text"
                               id="Input_MasterKey_RowKey"
                               placeholder="Row Key"
                               readonly="readonly" />
                    </div>

                    <!-- Partition Key dropdown -->
                    <div class="input-field col s4">
                        @* Dropdown trong form *@
                        <select id="Select_MasterValueInContext_PartitionKey"
                                name="MasterValueInContext.PartitionKey"
                                required="required">
                            <option value="">--Select--</option>
                            @if (ViewBag.MasterKeys != null)
                            {
                                foreach (var key in (IEnumerable<ASC.Model.Models.MasterDataKey>)ViewBag.MasterKeys)
                                {
                                    <option value="@key.PartitionKey">@key.Name</option>
                                }
                            }
                        </select>
                        <label>Partition Key</label>
                    </div>

                    <!-- Name -->
                    <div class="input-field col s4">
                        <input type="text"
                               id="MasterValueInContext_Name"
                               name="MasterValueInContext.Name"
                               class="validate"
                               placeholder="Name" />
                    </div>
                </div>

                <div class="row">
                    <!-- Is Active -->
                    <div class="col s4" style="margin-top: 20px;">
                        <div class="switch">
                            <label>
                                Is Active
                                <input type="checkbox"
                                       id="MasterValueInContext_IsActive"
                                       name="MasterValueInContext.IsActive"
                                       value="true"
                                       onclick="this.value = this.checked ? 'true' : 'false'" />
                                <span class="lever"></span>
                            </label>
                        </div>
                    </div>

                    <div class="input-field col s8 right-align">
                        <button class="btn waves-effect waves-light btnSubmit" type="button">
                            Create
                            <i class="material-icons right">send</i>
                        </button>
                        <button class="btn waves-effect waves-light reset red lighten-1" type="button">
                            Reset
                        </button>
                    </div>
                    <div class="row col s12 right-align" asp-validation-summary="All"></div>
                </div>
            </form>
        </div>
        <div class="row"></div>
    </div>
</div>

<!-- Modal Structure -->
<div id="modal1" class="modal modal-fixed-footer">
    <div class="modal-content">
        <h4>Upload Excel</h4>
        <p>Upload the Excel file that contains all the master values.</p>
        <!-- Div to display Errors-->
        <div class="row hide divErrors">
            <div class="col s12">
                <div class="card-panel red lighten-1">
                    <span class="white-text errors"></span>
                </div>
            </div>
        </div>
        <!-- Div to display progress -->
        <div class="progress hide">
            <div class="indeterminate"></div>
        </div>
        <form asp-controller="MasterData" asp-action="UploadExcel" asp-area="Configuration" method="post" enctype="multipart/form-data" id="formUploadExcel">
            @Html.AntiForgeryToken()
            <div class="file-field input-field">
                <div class="btn">
                    <span>File</span>
                    <input type="file" id="files">
                </div>
                <div class="file-path-wrapper">
                    <input class="file-path validate" type="text">
                </div>
                <div class="input-field row right">
                    <button class="btn waves-effect waves-light btnUpload" type="button" name="action">
                        Upload
                        <i class="material-icons right">send</i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Need to pass Verification Token to get Request Validated for Forgery
            var token = $('input[type=hidden][name=__RequestVerificationToken]', document).val();
            $.ajaxSetup({
                // Disable caching of AJAX responses
                cache: false,
                headers: { 'RequestVerificationToken': token }
            });
            // Initialize DataTable to show list of Master Values
            var table = $('#tblMasterValues').DataTable({
                // Make AJAX call based on get Master Values from Server
                'ajax': {
                    'url': '@Url.Action("MasterValuesByKey", "MasterData")',
                    'type': 'GET',
                     data: function (d) {
                        d.key = $('#ddlMasterKeys').val();
                     }
                },
                'pageLength': 3,
                // Number of records to be displayed per page
                'lengthMenu': [[3, 5, 10, -1], [3, 5, 10, 'All']],
                // Set Columns
                'columns': [
                    { 'data': 'rowKey' },
                    { 'data': 'partitionKey' },
                    { 'data': 'name' },
                    { 'data': 'isActive' },
                    { 'data': null }
                ],
                "aoColumnDefs": [
                    {
                        "aTargets": [3],
                        "mData": "isActive",
                        "mRender": function (data) {
                            return data === true
                                ? '<img src="/images/green_tick.png" width="30" height="30" />'
                                : '<img src="/images/red_cross.png" width="30" height="30"/>';
                        }
                    },
                    {
                        "aTargets": [4],
                        "mData": null,
                        "mRender": function () {
                            return '<i class="small material-icons edit cursor-hand">mode_edit</i>';
                        }
                    }
                ]
            });
                    // Auto select key nếu có
        var selectedKey = '@ViewBag.SelectedKey';
        if (selectedKey && selectedKey !== '') {
            $('#ddlMasterKeys').val(selectedKey);
            $('select').formSelect();
            table.ajax.url('@Url.Action("MasterValuesByKey", "MasterData")' + '?key=' + selectedKey);
            table.ajax.reload();
        }
            // Set Styles for DataTable and Number of Records to be displayed in drop-down
            $('#tblMasterValues').css("width", "100%");
            $('select[name="tblMasterValues_length"]').formSelect();
            $("select[required]").css({
                display: "block", position: 'absolute', visibility: 'hidden'
            });
            // Initialize Master Key Select
            $('select').formSelect();

            // On click of Edit icon, populate the details section with details of service engineer
            $(document).on('click', '.edit', function () {
                var user = table.row($(this).parents('tr')).data();
                console.log(user);

                $('#IsEdit').val('True');
                $('#MasterValueInContext_RowKey').val(user.rowKey);
                $('#Input_MasterKey_RowKey').val(user.rowKey);
                $('#MasterValueInContext_PartitionKey').val(user.partitionKey);

                $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
                $('#Select_MasterValueInContext_PartitionKey').val(user.partitionKey);
                $('#Select_MasterValueInContext_PartitionKey')
                    .attr('disabled', 'disabled')
                    .formSelect();

                $('.select-wrapper').removeClass('valid');
                $('#MasterValueInContext_Name').val(user.name).addClass('valid');
                $('#MasterValueInContext_IsActive').prop('checked', user.isActive === true);

                $('.btnSubmit').text('Save');
                M.updateTextFields();
            });

            // Handle Reset
            $(document).on('click', '.reset', function () {
                $('#IsEdit').val('False');
                $('#MasterValueInContext_RowKey').val('');
                $('#Input_MasterKey_RowKey').val('');
                $('#MasterValueInContext_PartitionKey').val('');
                $('#MasterValueInContext_Name').val('').removeClass('valid');
                $('#MasterValueInContext_IsActive').prop('checked', false);

                $('#Select_MasterValueInContext_PartitionKey').formSelect('destroy');
                $('#Select_MasterValueInContext_PartitionKey').removeAttr('disabled');
                $('#Select_MasterValueInContext_PartitionKey').val('');
                $('#Select_MasterValueInContext_PartitionKey').formSelect();

                $('.btnSubmit').text('Create');
                $('.select-wrapper').removeClass('valid');
                M.updateTextFields();
            });

            // Dropdown change event
            $(document).on('change', '#ddlMasterKeys', function () {
                table.ajax.url('@Url.Action("MasterValuesByKey", "MasterData")' + '?key=' + $('#ddlMasterKeys').val());
                table.ajax.reload();
            });

            // Save/Create Button Click Event
            $(document).on('click', '.btnSubmit', function () {
                var form = $("#formMasterValue");
                if ($(form).valid()) {
                    var masterData = {};
                    masterData.Name = $('#MasterValueInContext_Name').val();
                    masterData.PartitionKey = $('#Select_MasterValueInContext_PartitionKey').val();
                    masterData.IsActive = $('#MasterValueInContext_IsActive').is(':checked');

                if ($('#IsEdit').val() === "True") {
                    masterData.RowKey = $('#MasterValueInContext_RowKey').val();
                    masterData.PartitionKey = $('#MasterValueInContext_PartitionKey').val();
                } else {
                    masterData.PartitionKey = $('#Select_MasterValueInContext_PartitionKey').val();
                }

                    console.log(masterData);

                    $.post('@Url.Action("MasterValues", "MasterData")',
                        { masterValue: masterData, isEdit: $('#IsEdit').val() === 'True' },
                        function (data) {
                            if (data.success) {
                            // SET lại dropdown theo dữ liệu vừa tạo
                            $('#ddlMasterKeys').val(masterData.PartitionKey);
                            $('select').formSelect();

                            // reload đúng key
                            table.ajax.url('@Url.Action("MasterValuesByKey", "MasterData")' + '?key=' + masterData.PartitionKey);
                            table.ajax.reload();

                            $('.reset').click();
                        }
                            else {
                            alert("Save failed");
                            }
        }
                    );
                }
            });

            // Upload Excel Button Click Event
            $(document).on('click', '.btnUpload', function () {
                // Get all files from input file tag
                var fileUpload = $("#files").get(0);
                var files = fileUpload.files;
                var data = new FormData();
                // Process the file and create FormData object
                data.append('file', files[0]);
                // Show progress bar
                $(".progress").removeClass("hide");
                $.ajax({
                    type: "POST",
                    url: "/Configuration/MasterData/UploadExcel",
                    contentType: false,
                    processData: false,
                    data: data,
                    headers: { 'RequestVerificationToken': token },

                     success: function (message) {

                        $(".progress").addClass("hide");

                        if (message.success) {

                            // đóng modal
                            var instance = M.Modal.getInstance(document.getElementById('modal1'));
                            if (instance) instance.close();

                            // clear file
                            $('#files').val('');
                            $('.file-path').val('');

                            // redirect với key
                            window.location.href = window.location.pathname + '?selectedKey=' + message.key;

                        } else if (message.error) {

                            $(".divErrors").removeClass("hide");
                            $(".errors").html(message.text);
                        }
                    }
                });
            });

            $('.modal').modal();
        });
    </script>
}
